# === Domain ===
BASE_DOMAIN=groumo.com

# === Let's Encrypt ===
ACME_EMAIL=admin@groumo.com

# === Traefik Dashboard (htpasswd format) ===
# Generate: echo $(htpasswd -nB admin) | sed -e s/\\$/\\$\\$/g
TRAEFIK_DASHBOARD_AUTH=admin:$$2y$$05$$...

# === Supabase (GROUMO_SETTING 전용) ===
SUPABASE_URL=https://your-groumo-setting-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:6543/postgres

# === Supabase (GROUMO_TEMPLATE 전용) ===
# 테넌트 Frontend에서 사용할 Supabase (GROUMO_SETTING과 완전히 분리)
TEMPLATE_SUPABASE_URL=https://your-groumo-template-project.supabase.co
TEMPLATE_SUPABASE_ANON_KEY=template-anon-key
TEMPLATE_SUPABASE_SERVICE_ROLE_KEY=template-service-role-key

# === Admin API ===
ADMIN_API_KEY=your-secure-api-key

# === Tenant Docker Images (GHCR) ===
GHCR_BACKEND_IMAGE=ghcr.io/your-org/groumo-tenant-backend:latest
GHCR_FRONTEND_IMAGE=ghcr.io/your-org/groumo-tenant-frontend:latest
