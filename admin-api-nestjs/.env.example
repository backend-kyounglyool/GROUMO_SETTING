# Server
PORT=5000
NODE_ENV=development

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database (direct connection via pgbouncer)
DATABASE_URL=postgresql://postgres.your-project:your-password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true

# Docker
DOCKER_SOCKET=/var/run/docker.sock
DOCKER_NETWORK=traefik-network

# GitHub Container Registry
GHCR_BACKEND_IMAGE=ghcr.io/your-org/your-repo/backend:latest
GHCR_FRONTEND_IMAGE=ghcr.io/your-org/your-repo/frontend:latest

# Domain
BASE_DOMAIN=groumo.com

# Security
ADMIN_API_KEY=your-secure-api-key
